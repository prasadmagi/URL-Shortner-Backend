generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  urls      Url[]
}

model Url {
  id        Int       @id @default(autoincrement())
  shortCode String    @unique
  longUrl   String
  clicks    Int       @default(0)
  ipAddress String?
  createdAt DateTime @default(now())

  userId    Int?
  user      User?     @relation(fields: [userId], references: [id])
}